---
import { getAdminArticleSummaries, getAdminProjectSummaries, type ArticleSummary, type ProjectSummary } from '../../lib/db';
import { getRuntimeEnv } from '../../lib/runtime';
import { formatDate } from '../../utils/date';
import config from '../../../config.json';

const env = getRuntimeEnv(Astro.locals);

let articles: ArticleSummary[] = [];
try {
  articles = await getAdminArticleSummaries(env);
} catch (err) {
  console.error('Admin list DB error:', err);
}

let projects: ProjectSummary[] = [];
try {
  projects = await getAdminProjectSummaries(env);
} catch (err) {
  console.error('Admin projects DB error:', err);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — {config.site_name}</title>
    <meta name="robots" content="noindex, nofollow" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      try {
        const svdTheme = localStorage.getItem('theme');
        if (svdTheme) document.documentElement.setAttribute('data-theme', svdTheme);
        else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)
          document.documentElement.setAttribute('data-theme', 'dark');
      } catch (_) {}
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        color: #222;
        min-height: 100vh;
      }

      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #ddd;
      }

      h1 {
        font-size: 1.5rem;
        font-weight: 700;
      }
      h2 {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: 1rem;
      }

      /* ── Tabs ── */
      .tabs {
        display: flex;
        gap: 0;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid #e0e0e0;
      }

      .tab-btn {
        padding: 0.6rem 1.25rem;
        font-size: 0.9rem;
        font-weight: 500;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        cursor: pointer;
        color: #888;
        border-radius: 0;
        transition: color 0.15s, border-color 0.15s;
      }

      .tab-btn:hover {
        color: #333;
      }

      .tab-btn.active {
        color: #222;
        border-bottom-color: #222;
      }

      .tab-panel {
        display: none;
      }

      .tab-panel.active {
        display: block;
      }

      /* ── Cards ── */
      .card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
      }

      .form-group {
        margin-bottom: 1rem;
      }

      label {
        display: block;
        font-size: 0.85rem;
        font-weight: 500;
        color: #555;
        margin-bottom: 0.35rem;
      }

      input[type='text'],
      input[type='date'],
      textarea {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid #ccc;
        border-radius: 5px;
        font-size: 0.95rem;
        font-family: inherit;
        background: #fafafa;
      }

      textarea {
        font-family: 'SF Mono', ui-monospace, Menlo, Consolas, monospace;
        font-size: 0.85rem;
        resize: vertical;
      }

      input:focus,
      textarea:focus {
        outline: 2px solid #333;
        outline-offset: 1px;
        background: #fff;
      }

      .checkbox-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .checkbox-group input[type='checkbox'] {
        width: 16px;
        height: 16px;
      }

      .checkbox-group label {
        margin: 0;
        font-weight: 400;
        color: #333;
      }

      .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      button {
        padding: 0.5rem 1.25rem;
        border-radius: 5px;
        border: 1px solid #333;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
      }

      .btn-primary {
        background: #222;
        color: #fff;
        border-color: #222;
      }

      .btn-primary:hover {
        background: #444;
      }

      .btn-danger {
        background: none;
        color: #c0392b;
        border-color: #c0392b;
        padding: 0.3rem 0.75rem;
        font-size: 0.8rem;
      }

      .btn-danger:hover {
        background: #c0392b;
        color: #fff;
      }

      .btn-sm {
        padding: 0.3rem 0.75rem;
        font-size: 0.8rem;
      }

      .item-list {
        list-style: none;
      }

      .item-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 0.85rem 0;
        border-bottom: 1px dashed #e0e0e0;
        gap: 1rem;
      }

      .item-row:last-child {
        border-bottom: none;
      }

      .item-info {
        flex: 1;
        min-width: 0;
      }

      .item-title-link {
        font-weight: 500;
        font-size: 0.95rem;
        color: #222;
        text-decoration: none;
      }

      .item-title-link:hover {
        text-decoration: underline;
      }

      .item-meta {
        font-size: 0.8rem;
        color: #888;
        margin-top: 0.2rem;
      }

      .badge {
        display: inline-block;
        font-size: 0.7rem;
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        background: #e8f5e9;
        color: #2e7d32;
        font-weight: 600;
        margin-left: 0.4rem;
      }

      .badge-hidden {
        background: #fff3e0;
        color: #e65100;
      }

      .item-actions {
        display: flex;
        gap: 0.5rem;
        align-items: center;
      }

      .logout-link {
        font-size: 0.85rem;
        padding: 0.35rem 0.75rem;
        border: 1px solid #333;
        border-radius: 5px;
        color: #333;
        text-decoration: none;
        font-weight: 500;
      }

      .logout-link:hover {
        background: #f0f0f0;
      }

      .empty {
        color: #888;
        font-style: italic;
        font-size: 0.9rem;
      }

      /* ── Markdown editor split pane ── */
      .md-editor-wrap {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border: 1px solid #ccc;
        border-radius: 5px;
        overflow: hidden;
      }
      .md-editor-wrap textarea {
        border: none;
        border-right: 1px solid #ccc;
        border-radius: 0;
        resize: none;
        outline: none;
      }
      .md-editor-wrap textarea:focus {
        outline: none;
        background: #fff;
      }
      .md-preview-pane {
        overflow-y: auto;
        padding: 0.75rem 1rem;
        font-family: ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif;
        font-size: 1rem;
        line-height: 1.8;
        color: #222;
        background: #fafafa;
      }
      .md-preview-pane.empty::before {
        content: 'Preview will appear here…';
        color: #aaa;
        font-style: italic;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 0.85rem;
      }
      .md-editor-header {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }
      .md-editor-header span {
        font-size: 0.75rem;
        font-weight: 600;
        color: #888;
        padding: 0.3rem 0.75rem;
        background: #f0f0f0;
        border: 1px solid #ccc;
        border-bottom: none;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .md-editor-header span:first-child {
        border-right: none;
        border-radius: 5px 0 0 0;
      }
      .md-editor-header span:last-child {
        border-left: 1px solid #ccc;
        border-radius: 0 5px 0 0;
      }

      /* Preview typography */
      .md-preview-pane p { margin-bottom: 1.25rem; }
      .md-preview-pane h1, .md-preview-pane h2, .md-preview-pane h3,
      .md-preview-pane h4, .md-preview-pane h5, .md-preview-pane h6 {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-weight: 700; line-height: 1.2; margin-top: 2rem; margin-bottom: 0.6rem;
      }
      .md-preview-pane h2 { font-size: 1.4rem; border-bottom: 1px solid #efefef; padding-bottom: 0.3rem; }
      .md-preview-pane h3 { font-size: 1.15rem; }
      .md-preview-pane ul, .md-preview-pane ol { padding-left: 1.5rem; margin-bottom: 1.25rem; }
      .md-preview-pane ul { list-style: disc; }
      .md-preview-pane ol { list-style: decimal; }
      .md-preview-pane li { margin-bottom: 0.35rem; }
      .md-preview-pane blockquote {
        border-left: 3px solid #efefef; padding: 0.2rem 0 0.2rem 1rem;
        color: #888; font-style: italic; margin: 0 0 1.25rem 0;
      }
      .md-preview-pane strong, .md-preview-pane b { font-weight: 700; }
      .md-preview-pane em, .md-preview-pane i { font-style: italic; }
      .md-preview-pane code {
        font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
        font-size: 0.85em; background: #efefef; padding: 0.15em 0.4em; border-radius: 3px;
      }
      .md-preview-pane pre {
        background: #f6f8fa; border: 1px solid #efefef; border-radius: 6px;
        padding: 0.85rem 1rem; overflow-x: auto; margin-bottom: 1.25rem;
        font-size: 0.85rem; line-height: 1.6;
      }
      .md-preview-pane pre code { background: none; padding: 0; border-radius: 0; }
      .md-preview-pane hr { border: none; border-top: 1px dashed #efefef; margin: 2rem 0; }
      .md-preview-pane a { text-decoration: underline; }
      .md-preview-pane img { max-width: 100%; border-radius: 6px; }

      /* ── Dark mode ── */
      [data-theme='dark'] body {
        background: #111;
        color: #efefef;
      }
      [data-theme='dark'] .card {
        background: #1a1a1a;
        border-color: #333;
      }
      [data-theme='dark'] header {
        border-bottom-color: #333;
      }
      [data-theme='dark'] .tabs {
        border-bottom-color: #333;
      }
      [data-theme='dark'] .tab-btn {
        color: #666;
      }
      [data-theme='dark'] .tab-btn:hover {
        color: #aaa;
      }
      [data-theme='dark'] .tab-btn.active {
        color: #efefef;
        border-bottom-color: #efefef;
      }
      [data-theme='dark'] label {
        color: #aaa;
      }
      [data-theme='dark'] .checkbox-group label {
        color: #ccc;
      }
      [data-theme='dark'] input[type='text'],
      [data-theme='dark'] input[type='date'],
      [data-theme='dark'] textarea {
        background: #222;
        border-color: #444;
        color: #efefef;
      }
      [data-theme='dark'] input:focus,
      [data-theme='dark'] textarea:focus {
        outline-color: #aaa;
        background: #2a2a2a;
      }
      [data-theme='dark'] button {
        border-color: #aaa;
      }
      [data-theme='dark'] .btn-primary {
        background: #efefef;
        color: #111;
        border-color: #efefef;
      }
      [data-theme='dark'] .btn-primary:hover {
        background: #ccc;
        border-color: #ccc;
      }
      [data-theme='dark'] .item-row {
        border-bottom-color: #333;
      }
      [data-theme='dark'] .item-title-link {
        color: #efefef;
      }
      [data-theme='dark'] .badge {
        background: #1a3a1a;
        color: #6fcf97;
      }
      [data-theme='dark'] .badge-hidden {
        background: #3a2a1a;
        color: #ffb74d;
      }
      [data-theme='dark'] .logout-link {
        border-color: #aaa;
        color: #ccc;
      }
      [data-theme='dark'] .logout-link:hover {
        background: #222;
      }

      /* Dark mode: editor split pane */
      [data-theme='dark'] .md-editor-wrap { border-color: #444; }
      [data-theme='dark'] .md-editor-wrap textarea { border-right-color: #444; }
      [data-theme='dark'] .md-preview-pane { background: #1e1e1e; color: #efefef; }
      [data-theme='dark'] .md-editor-header span { background: #1a1a1a; border-color: #444; color: #666; }
      [data-theme='dark'] .md-editor-header span:last-child { border-left-color: #444; }
      [data-theme='dark'] .md-preview-pane h2 { border-bottom-color: #333; }
      [data-theme='dark'] .md-preview-pane blockquote { border-left-color: #444; color: #888; }
      [data-theme='dark'] .md-preview-pane code { background: #2a2a2a; }
      [data-theme='dark'] .md-preview-pane pre { background: #161b22; border-color: #30363d; }
      [data-theme='dark'] .md-preview-pane hr { border-top-color: #444; }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>Admin — {config.site_name}</h1>
        <div style="display:flex;gap:0.75rem;align-items:center;">
          <a href="/" style="font-size:0.85rem;color:#666;">← View site</a>
          <a href="/cdn-cgi/access/logout" class="logout-link">Logout</a>
        </div>
      </header>

      <!-- Tabs -->
      <div class="tabs">
        <button class="tab-btn active" data-tab="articles">
          Articles ({articles.length})
        </button>
        <button class="tab-btn" data-tab="projects">
          Projects ({projects.length})
        </button>
      </div>

      <!-- ── Articles Tab ── -->
      <div id="tab-articles" class="tab-panel active">
        <!-- New Article Form -->
        <div class="card">
          <h2>New Article</h2>
          <form method="POST" action="/api/articles">
            <div class="row">
              <div class="form-group">
                <label for="a-title">Title *</label>
                <input type="text" id="a-title" name="title" required placeholder="Judul artikel" />
              </div>
              <div class="form-group">
                <label for="a-slug">Slug *</label>
                <input type="text" id="a-slug" name="slug" required placeholder="judul-artikel" />
              </div>
            </div>

            <div class="row">
              <div class="form-group">
                <label for="a-date">Date *</label>
                <input
                  type="date"
                  id="a-date"
                  name="date"
                  required
                  value={new Date().toISOString().slice(0, 10)}
                />
              </div>
              <div class="form-group" style="display:flex;align-items:flex-end;gap:1.25rem;">
                <div class="checkbox-group">
                  <input type="checkbox" id="a-featured" name="featured" value="1" />
                  <label for="a-featured">Featured article</label>
                </div>
                <div class="checkbox-group">
                  <input type="checkbox" id="a-hidden" name="hidden" value="1" />
                  <label for="a-hidden">Hidden (draft)</label>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label for="a-description">Description (SEO/RSS)</label>
              <input
                type="text"
                id="a-description"
                name="description"
                placeholder="Ringkasan singkat artikel (opsional)"
              />
            </div>

            <div class="form-group">
              <label for="a-content">Content (Markdown) *</label>
              <div class="md-editor-header">
                <span>Markdown</span>
                <span>Preview</span>
              </div>
              <div class="md-editor-wrap">
                <textarea
                  id="a-content"
                  name="content"
                  rows="18"
                  required
                  placeholder="Tulis artikel dalam format Markdown..."></textarea>
                <div class="md-preview-pane empty" id="a-md-preview" style="min-height:calc(18 * 1.5rem + 1rem)" aria-live="polite"></div>
              </div>
            </div>

            <button type="submit" class="btn-primary">Publish Article</button>
          </form>
        </div>

        <!-- Articles List -->
        <div class="card">
          <h2>All Articles ({articles.length})</h2>
          {
            articles.length === 0 ? (
              <p class="empty">Belum ada artikel.</p>
            ) : (
              <ul class="item-list">
                {articles.map((article) => (
                  <li class="item-row">
                    <div class="item-info">
                      <a
                        href={`/writing/${article.slug}`}
                        target="_blank"
                        class="item-title-link"
                      >
                        {article.title}
                        {article.featured && <span class="badge">featured</span>}
                        {article.hidden && <span class="badge badge-hidden">hidden</span>}
                      </a>
                      <div class="item-meta">
                        {formatDate(article.date)} &middot; /writing/{article.slug}
                      </div>
                    </div>
                    <div class="item-actions">
                      <a
                        href={`/admin/edit/${article.slug}`}
                        class="btn-sm"
                        style="padding:0.3rem 0.75rem;border:1px solid #ccc;border-radius:5px;font-size:0.8rem;color:#333;text-decoration:none;"
                      >
                        Edit
                      </a>
                      <form method="POST" action="/api/articles">
                        <input type="hidden" name="_action" value="set_hidden" />
                        <input type="hidden" name="slug" value={article.slug} />
                        <input type="hidden" name="hidden" value={article.hidden ? '0' : '1'} />
                        <button
                          type="submit"
                          class="btn-sm"
                          style={`padding:0.3rem 0.75rem;border-radius:5px;font-size:0.8rem;cursor:pointer;border:1px solid ${article.hidden ? '#2e7d32' : '#e65100'};color:${article.hidden ? '#2e7d32' : '#e65100'};background:none;`}
                        >
                          {article.hidden ? 'Unhide' : 'Hide'}
                        </button>
                      </form>
                      <form
                        method="POST"
                        action="/api/articles"
                        onsubmit="return confirm('Hapus artikel ini?')"
                      >
                        <input type="hidden" name="_action" value="delete" />
                        <input type="hidden" name="slug" value={article.slug} />
                        <button type="submit" class="btn-danger">Delete</button>
                      </form>
                    </div>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </div>

      <!-- ── Projects Tab ── -->
      <div id="tab-projects" class="tab-panel">
        <!-- New Project Form -->
        <div class="card">
          <h2>New Project</h2>
          <form method="POST" action="/api/projects">
            <div class="row">
              <div class="form-group">
                <label for="p-title">Title *</label>
                <input type="text" id="p-title" name="title" required placeholder="Nama project" />
              </div>
              <div class="form-group">
                <label for="p-slug">Slug *</label>
                <input
                  type="text"
                  id="p-slug"
                  name="slug"
                  required
                  placeholder="nama-project"
                />
              </div>
            </div>

            <div class="row">
              <div class="form-group">
                <label for="p-date">Date *</label>
                <input
                  type="date"
                  id="p-date"
                  name="date"
                  required
                  value={new Date().toISOString().slice(0, 10)}
                />
              </div>
              <div class="form-group" style="display:flex;align-items:flex-end;gap:1.25rem;">
                <div class="checkbox-group">
                  <input type="checkbox" id="p-featured" name="featured" value="1" />
                  <label for="p-featured">Featured</label>
                </div>
                <div class="checkbox-group">
                  <input type="checkbox" id="p-hidden" name="hidden" value="1" />
                  <label for="p-hidden">Hidden (draft)</label>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label for="p-url">Project URL</label>
              <input
                type="text"
                id="p-url"
                name="url"
                placeholder="https://github.com/user/repo (opsional)"
              />
            </div>

            <div class="form-group">
              <label for="p-description">Description</label>
              <input
                type="text"
                id="p-description"
                name="description"
                placeholder="Ringkasan singkat project (opsional)"
              />
            </div>

            <div class="form-group">
              <label for="p-content">Content (Markdown)</label>
              <div class="md-editor-header">
                <span>Markdown</span>
                <span>Preview</span>
              </div>
              <div class="md-editor-wrap">
                <textarea
                  id="p-content"
                  name="content"
                  rows="12"
                  placeholder="Deskripsi panjang project dalam Markdown (opsional)..."></textarea>
                <div class="md-preview-pane empty" id="p-md-preview" style="min-height:calc(12 * 1.5rem + 1rem)" aria-live="polite"></div>
              </div>
            </div>

            <button type="submit" class="btn-primary">Publish Project</button>
          </form>
        </div>

        <!-- Projects List -->
        <div class="card">
          <h2>All Projects ({projects.length})</h2>
          {
            projects.length === 0 ? (
              <p class="empty">Belum ada project.</p>
            ) : (
              <ul class="item-list">
                {projects.map((project) => (
                  <li class="item-row">
                    <div class="item-info">
                      <a
                        href={`/projects/${project.slug}`}
                        target="_blank"
                        class="item-title-link"
                      >
                        {project.title}
                        {project.featured && <span class="badge">featured</span>}
                        {project.hidden && <span class="badge badge-hidden">hidden</span>}
                      </a>
                      <div class="item-meta">
                        {formatDate(project.date)} &middot; /projects/{project.slug}
                        {project.url && (
                          <>
                            {' '}
                            &middot;{' '}
                            <a
                              href={project.url}
                              target="_blank"
                              style="color:inherit;"
                            >
                              {project.url.replace(/^https?:\/\//, '')}
                            </a>
                          </>
                        )}
                      </div>
                    </div>
                    <div class="item-actions">
                      <a
                        href={`/admin/projects/edit/${project.slug}`}
                        class="btn-sm"
                        style="padding:0.3rem 0.75rem;border:1px solid #ccc;border-radius:5px;font-size:0.8rem;color:#333;text-decoration:none;"
                      >
                        Edit
                      </a>
                      <form method="POST" action="/api/projects">
                        <input type="hidden" name="_action" value="set_hidden" />
                        <input type="hidden" name="slug" value={project.slug} />
                        <input type="hidden" name="hidden" value={project.hidden ? '0' : '1'} />
                        <button
                          type="submit"
                          class="btn-sm"
                          style={`padding:0.3rem 0.75rem;border-radius:5px;font-size:0.8rem;cursor:pointer;border:1px solid ${project.hidden ? '#2e7d32' : '#e65100'};color:${project.hidden ? '#2e7d32' : '#e65100'};background:none;`}
                        >
                          {project.hidden ? 'Unhide' : 'Hide'}
                        </button>
                      </form>
                      <form
                        method="POST"
                        action="/api/projects"
                        onsubmit="return confirm('Hapus project ini?')"
                      >
                        <input type="hidden" name="_action" value="delete" />
                        <input type="hidden" name="slug" value={project.slug} />
                        <button type="submit" class="btn-danger">Delete</button>
                      </form>
                    </div>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </div>
    </div>

    <script is:inline>
      // ── Live markdown preview (shared loader) ──
      (async () => {
        const { marked } = await import('https://cdn.jsdelivr.net/npm/marked@15/lib/marked.esm.js');
        marked.use({ renderer: { html: () => '' } });

        function bindPreview(textareaId, previewId) {
          const textarea = document.getElementById(textareaId);
          const preview = document.getElementById(previewId);
          if (!textarea || !preview) return;

          async function updatePreview() {
            const raw = textarea.value;
            if (!raw.trim()) {
              preview.innerHTML = '';
              preview.classList.add('empty');
              return;
            }
            const html = await marked.parse(raw, { gfm: true, breaks: false });
            preview.innerHTML = html;
            preview.classList.remove('empty');
          }

          let timer;
          textarea.addEventListener('input', () => {
            clearTimeout(timer);
            timer = setTimeout(updatePreview, 150);
          });

          textarea.addEventListener('scroll', () => {
            const ratio = textarea.scrollTop / (textarea.scrollHeight - textarea.clientHeight || 1);
            preview.scrollTop = ratio * (preview.scrollHeight - preview.clientHeight);
          });

          updatePreview();
        }

        bindPreview('a-content', 'a-md-preview');
        bindPreview('p-content', 'p-md-preview');
      })();
    </script>

    <script>
      // ── Tab switching ──
      const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
      const tabPanels = document.querySelectorAll<HTMLDivElement>('.tab-panel');

      function activateTab(name: string) {
        tabBtns.forEach((btn) => btn.classList.toggle('active', btn.dataset.tab === name));
        tabPanels.forEach((panel) => panel.classList.toggle('active', panel.id === `tab-${name}`));
        history.replaceState(null, '', `#${name}`);
      }

      tabBtns.forEach((btn) => {
        btn.addEventListener('click', () => activateTab(btn.dataset.tab!));
      });

      // Restore tab from URL hash on load
      const hash = location.hash.replace('#', '');
      if (hash === 'articles' || hash === 'projects') activateTab(hash);

      // ── Auto-generate slug (articles) ──
      const aTitleInput = document.getElementById('a-title');
      const aSlugInput = document.getElementById('a-slug');
      if (aTitleInput && aSlugInput) {
        aTitleInput.addEventListener('input', () => {
          if (!(aSlugInput as HTMLInputElement).dataset.edited) {
            (aSlugInput as HTMLInputElement).value = (aTitleInput as HTMLInputElement).value
              .toLowerCase()
              .replace(/[^a-z0-9\s-]/g, '')
              .trim()
              .replace(/\s+/g, '-');
          }
        });
        aSlugInput.addEventListener('input', () => {
          (aSlugInput as HTMLElement).dataset.edited = '1';
        });
      }

      // ── Auto-generate slug (projects) ──
      const pTitleInput = document.getElementById('p-title');
      const pSlugInput = document.getElementById('p-slug');
      if (pTitleInput && pSlugInput) {
        pTitleInput.addEventListener('input', () => {
          if (!(pSlugInput as HTMLInputElement).dataset.edited) {
            (pSlugInput as HTMLInputElement).value = (pTitleInput as HTMLInputElement).value
              .toLowerCase()
              .replace(/[^a-z0-9\s-]/g, '')
              .trim()
              .replace(/\s+/g, '-');
          }
        });
        pSlugInput.addEventListener('input', () => {
          (pSlugInput as HTMLElement).dataset.edited = '1';
        });
      }
    </script>
  </body>
</html>

---
import { getArticleBySlug, type Article } from '../../../lib/db';
import { getRuntimeEnv } from '../../../lib/runtime';
import config from '../../../../config.json';

const env = getRuntimeEnv(Astro.locals);

const { slug } = Astro.params;
let article: Article | null = null;
try {
  article = await getArticleBySlug(slug!, env);
} catch (err) {
  console.error('Edit article fetch error:', err);
  return Astro.redirect('/admin');
}

if (!article) {
  return Astro.redirect('/admin');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit: {article.title} — {config.site_name}</title>
    <meta name="robots" content="noindex, nofollow" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      try {
        const svdTheme = localStorage.getItem('theme');
        if (svdTheme) document.documentElement.setAttribute('data-theme', svdTheme);
        else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)
          document.documentElement.setAttribute('data-theme', 'dark');
      } catch (_) {}
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        color: #222;
        min-height: 100vh;
      }

      /* ── Two-column layout ── */
      .page-layout {
        display: flex;
        align-items: flex-start;
        min-height: 100vh;
      }

      /* Left: form panel */
      .form-panel {
        flex: 1;
        min-width: 0;
        padding: 2rem 1.5rem;
        border-right: 1px solid #ddd;
        min-height: 100vh;
      }

      /* Right: preview panel */
      .preview-panel {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow: hidden;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #ddd;
      }
      h1 {
        font-size: 1.5rem;
        font-weight: 700;
      }
      h2 {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: 1rem;
      }
      .card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
      }
      .form-group {
        margin-bottom: 1rem;
      }
      label {
        display: block;
        font-size: 0.85rem;
        font-weight: 500;
        color: #555;
        margin-bottom: 0.35rem;
      }
      input[type='text'],
      input[type='date'],
      textarea {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid #ccc;
        border-radius: 5px;
        font-size: 0.95rem;
        font-family: inherit;
        background: #fafafa;
      }
      textarea {
        font-family: 'SF Mono', ui-monospace, Menlo, Consolas, monospace;
        font-size: 0.85rem;
        resize: vertical;
      }
      input:focus,
      textarea:focus {
        outline: 2px solid #333;
        outline-offset: 1px;
        background: #fff;
      }
      .checkbox-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .checkbox-group input[type='checkbox'] {
        width: 16px;
        height: 16px;
      }
      .checkbox-group label {
        margin: 0;
        font-weight: 400;
        color: #333;
      }
      .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      button {
        padding: 0.5rem 1.25rem;
        border-radius: 5px;
        border: 1px solid #333;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
      }
      .btn-primary {
        background: #222;
        color: #fff;
        border-color: #222;
      }
      .btn-primary:hover {
        background: #444;
      }
      a.back {
        font-size: 0.85rem;
        color: #666;
      }

      /* ── Preview panel ── */
      #preview-iframe {
        flex: 1;
        width: 100%;
        border: none;
        display: block;
      }

      .form-footer {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .save-status {
        font-size: 0.85rem;
        font-weight: 500;
        opacity: 0;
        transition: opacity 0.2s;
      }
      .save-status.visible { opacity: 1; }
      .save-status.ok  { color: #2d8a4e; }
      .save-status.err { color: #c0392b; }

      /* ── Dark mode ── */
      [data-theme='dark'] body {
        background: #111;
        color: #efefef;
      }
      [data-theme='dark'] .form-panel {
        border-right-color: #222;
      }
      [data-theme='dark'] .card {
        background: #1a1a1a;
        border-color: #333;
      }
      [data-theme='dark'] header {
        border-bottom-color: #333;
      }
      [data-theme='dark'] h2 {
        color: #efefef;
      }
      [data-theme='dark'] label {
        color: #aaa;
      }
      [data-theme='dark'] .checkbox-group label {
        color: #ccc;
      }
      [data-theme='dark'] input[type='text'],
      [data-theme='dark'] input[type='date'],
      [data-theme='dark'] textarea {
        background: #222;
        border-color: #444;
        color: #efefef;
      }
      [data-theme='dark'] input:focus,
      [data-theme='dark'] textarea:focus {
        outline-color: #aaa;
        background: #2a2a2a;
      }
      [data-theme='dark'] button {
        border-color: #aaa;
      }
      [data-theme='dark'] .btn-primary {
        background: #efefef;
        color: #111;
        border-color: #efefef;
      }
      [data-theme='dark'] .btn-primary:hover {
        background: #ccc;
        border-color: #ccc;
      }
      [data-theme='dark'] a.back {
        color: #888;
      }
    </style>
  </head>
  <body>
    <div class="page-layout">

      <!-- ── Left: form panel ── -->
      <div class="form-panel">
        <header>
          <h1>Edit Article</h1>
          <a href="/admin" class="back">← Back to admin</a>
        </header>

        <div class="card">
          <h2>{article.title}</h2>
          <form method="POST" action="/api/articles">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="original_slug" value={article.slug} />

            <div class="row">
              <div class="form-group">
                <label for="title">Title *</label>
                <input type="text" id="title" name="title" required value={article.title} />
              </div>
              <div class="form-group">
                <label for="slug">Slug *</label>
                <input type="text" id="slug" name="slug" required value={article.slug} />
              </div>
            </div>

            <div class="row">
              <div class="form-group">
                <label for="date">Date *</label>
                <input type="date" id="date" name="date" required value={article.date} />
              </div>
              <div class="form-group" style="display:flex;align-items:flex-end;gap:1.25rem;">
                <div class="checkbox-group">
                  <input
                    type="checkbox"
                    id="featured"
                    name="featured"
                    value="1"
                    checked={article.featured}
                  />
                  <label for="featured">Featured article</label>
                </div>
                <div class="checkbox-group">
                  <input
                    type="checkbox"
                    id="hidden"
                    name="hidden"
                    value="1"
                    checked={article.hidden}
                  />
                  <label for="hidden">Hidden (draft)</label>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label for="description">Description (SEO/RSS)</label>
              <input
                type="text"
                id="description"
                name="description"
                value={article.description ?? ''}
                placeholder="Ringkasan singkat artikel (opsional)"
              />
            </div>

            <div class="form-group">
              <label for="content">Content (Markdown) *</label>
              <textarea id="content" name="content" rows="28" required>{article.content}</textarea>
            </div>

            <div class="form-footer">
              <button type="submit" class="btn-primary" id="save-btn">Save Changes</button>
              <span class="save-status" id="save-status"></span>
            </div>
          </form>
        </div>
      </div>

      <!-- ── Right: preview panel ── -->
      <div class="preview-panel">
        <iframe id="preview-iframe" title="Article preview" sandbox="allow-same-origin"></iframe>
      </div>

    </div>

    <script is:inline>
      (async () => {
        const textarea  = document.getElementById('content');
        const titleEl   = document.getElementById('title');
        const dateEl    = document.getElementById('date');
        const iframe    = document.getElementById('preview-iframe');
        if (!textarea || !iframe) return;

        function getTheme() {
          return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        }

        async function updatePreview() {
          const fd = new FormData();
          fd.append('title',   titleEl ? titleEl.value : '');
          fd.append('date',    dateEl  ? dateEl.value  : '');
          fd.append('content', textarea.value);
          fd.append('theme',   getTheme());

          try {
            const res = await fetch('/api/preview', { method: 'POST', body: fd });
            if (res.ok) {
              iframe.srcdoc = await res.text();
            }
          } catch (_) {}
        }

        let previewTimer;
        function schedulePreview() {
          clearTimeout(previewTimer);
          previewTimer = setTimeout(updatePreview, 400);
        }

        textarea.addEventListener('input', schedulePreview);
        if (titleEl) titleEl.addEventListener('input', schedulePreview);
        if (dateEl)  dateEl.addEventListener('change', schedulePreview);

        // Initial render
        updatePreview();

        // ── Async save ──
        const form       = document.querySelector('form');
        const saveBtn    = document.getElementById('save-btn');
        const saveStatus = document.getElementById('save-status');

        function showStatus(msg, type) {
          saveStatus.textContent = msg;
          saveStatus.className = 'save-status visible ' + type;
        }
        function hideStatus() {
          saveStatus.className = 'save-status';
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          saveBtn.disabled = true;
          hideStatus();

          try {
            const data = new FormData(form);
            const res  = await fetch(form.action, {
              method: 'POST',
              body: data,
              headers: { 'X-Fetch': '1' },
            });

            if (res.ok) {
              const json = await res.json();
              // If slug changed, update the hidden original_slug so next save works
              const origInput = form.querySelector('[name="original_slug"]');
              if (origInput && json.slug) origInput.value = json.slug;
              showStatus('Saved', 'ok');
              setTimeout(hideStatus, 3000);
            } else {
              const txt = await res.text();
              showStatus(txt || 'Error', 'err');
            }
          } catch (err) {
            showStatus('Network error', 'err');
          } finally {
            saveBtn.disabled = false;
          }
        });
      })();
    </script>
  </body>
</html>

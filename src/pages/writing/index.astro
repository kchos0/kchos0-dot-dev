---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticleSummaries, type ArticleSummary } from '../../lib/db';
import { getRuntimeEnv } from '../../lib/runtime';
import config from '../../../config.json';
import { formatDate } from '../../utils/date';

const env = getRuntimeEnv(Astro.locals);
let sorted: ArticleSummary[] = [];
try {
  sorted = await getArticleSummaries(env);
} catch (err) {
  console.error('Writing list DB error:', err);
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=86400');
---

<BaseLayout title={`${config.site_name} — writing`} activeNav="writing">
  <section class="intro-section">
    <h1 class="hero-title">writing.</h1>
    <p class="intro-subtitle">my personal notes and interesting things.</p>
  </section>

  <section class="list-section">
    <ul class="clean-list">
      {
        sorted.length > 0 ? (
          sorted.map((article) => (
            <li>
              <a href={`/writing/${article.slug}`} class="list-link">
                <span class="list-meta date-meta">{formatDate(article.date)}</span>
                <span class="list-title article-title">{article.title}</span>
                {article.description && <p class="excerpt">{article.description}</p>}
              </a>
            </li>
          ))
        ) : (
          <li class="empty-item">
            <span class="list-meta" style="font-style: italic;">
              no writings published yet.
            </span>
          </li>
        )
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .empty-item {
    padding: 1.5rem 0;
  }
</style>

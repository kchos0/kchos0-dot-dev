---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticleBySlug, type Article } from '../../lib/db';
import { getRuntimeEnv } from '../../lib/runtime';
import config from '../../../config.json';
import { formatDate, getISODate } from '../../utils/date';
import { renderMarkdown } from '../../lib/markdown';

const { slug } = Astro.params;
const env = getRuntimeEnv(Astro.locals);

let article: Article | null = null;
try {
  article = await getArticleBySlug(slug!, env);
} catch (err) {
  console.error('Article fetch error:', err);
  return new Response('Service temporarily unavailable', { status: 503 });
}

if (!article) {
  return new Response(null, { status: 404 });
}

// Hidden articles are not publicly accessible
if (article.hidden) {
  return new Response(null, { status: 404 });
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=86400');

// Check if article has code blocks (to conditionally load copy button script)
const hasCodeBlocks = article.content.includes('```');

// Render Markdown → HTML (with caching)
const contentHtml = await renderMarkdown(article.content, {
  gfm: true,
  breaks: false,
});

const dateISO = getISODate(article.date);
const metaDescription = article.description || article.title;

const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? 'https://kchos0.dev';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: article.title,
  description: metaDescription,
  datePublished: dateISO,
  author: {
    '@type': 'Person',
    name: config.author,
    url: siteBase,
  },
  publisher: {
    '@type': 'Person',
    name: config.author,
  },
  url: `${siteBase}/writing/${article.slug}/`,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteBase}/writing/${article.slug}/`,
  },
};
---

<BaseLayout
  title={`${article.title} — ${config.site_name}`}
  description={metaDescription}
  activeNav="writing"
  ogType="article"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <a href="/writing" class="back-link">&larr; back to writing</a>

  <article>
    <header class="page-header">
      <h1 class="page-title">{article.title}</h1>
      <time class="page-date" datetime={dateISO}>{formatDate(article.date)}</time>
    </header>

    <div class="content-body" set:html={contentHtml} />
  </article>

{hasCodeBlocks && (
  <script>
    import { initCopyButtons } from '../../scripts/copy-button.js';
    initCopyButtons('.content-body');
  </script>
)}
</BaseLayout>

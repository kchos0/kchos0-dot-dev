---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjectSummaries, type ProjectSummary } from '../../lib/db';
import { getRuntimeEnv } from '../../lib/runtime';
import config from '../../../config.json';
import { formatDate } from '../../utils/date';

const env = getRuntimeEnv(Astro.locals);
let projects: ProjectSummary[] = [];
try {
  projects = await getProjectSummaries(env);
} catch (err) {
  console.error('Projects list DB error:', err);
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=86400');
---

<BaseLayout title={`${config.site_name} — projects`} activeNav="projects">
  <section class="intro-section">
    <h1 class="hero-title">projects.</h1>
    <p class="intro-subtitle">experiments, tools, and side quests I made in my free time.</p>
  </section>

  <section class="list-section">
    <ul class="clean-list">
      {
        projects.length > 0 ? (
          projects.map((project) => (
            <li>
              <a href={`/projects/${project.slug}`} class="list-link">
                <span class="list-meta date-meta">{formatDate(project.date)}</span>
                <span class="list-title project-title">{project.title}</span>
                {project.description && <p class="excerpt">{project.description}</p>}
                {project.url && (
                  <span class="project-url">{project.url.replace(/^https?:\/\//, '')}</span>
                )}
              </a>
            </li>
          ))
        ) : (
          <li class="empty-state">no projects published yet. check back later.</li>
        )
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .project-url {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .empty-state {
    padding: 2rem 0;
    color: var(--text-muted);
    font-style: italic;
  }
</style>

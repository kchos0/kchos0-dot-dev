---
import BaseLayout from '../../layouts/BaseLayout.astro';
import config from '../../../config.json';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { formatDate } from '../../utils/date';

const allProjects = await getCollection('projects');

const projects = allProjects.sort(
  (a, b) => Date.parse(b.data.date) - Date.parse(a.data.date)
);
---

<BaseLayout title={`${config.site_name} — projects`} activeNav="projects">
  <section class="intro-section">
    <h1 class="hero-title">projects.</h1>
    <p class="intro-subtitle">
      experiments, tools, and side quests I made in my free time.
    </p>
  </section>

  <section class="list-section">
    <ul class="clean-list">
      {projects.length > 0 ? projects.map((project) => (
        <li>
          <a
            href={project.data.link || '#'}
            class="list-link"
            target={project.data.link ? '_blank' : undefined}
            rel={project.data.link ? 'noopener noreferrer' : undefined}
          >
            {project.data.image && (
              <Image
                src={project.data.image}
                alt={project.data.title}
                width={600}
                height={315}
                class="project-image"
                loading="lazy"
                decoding="async"
              />
            )}
            <span class="list-meta date-meta">{formatDate(project.data.date)}</span>
            <span class="list-title project-title">{project.data.title}</span>
            <p class="project-description">{project.data.description}</p>
          </a>
        </li>
      )) : (
        <li class="empty-state">
          no projects published yet. check back later.
        </li>
      )}
    </ul>
  </section>
</BaseLayout>

<style>
  .intro-section {
    margin-bottom: var(--space-md);
  }

  @media (min-width: 768px) {
    .intro-section {
      margin-bottom: var(--space-lg);
    }
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-sm);
  }

  .intro-subtitle {
    font-family: var(--font-sans);
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .list-section {
    margin-bottom: var(--space-lg);
  }

  .clean-list {
    display: flex;
    flex-direction: column;
  }

  .list-link {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1.5rem 0;
    border-bottom: 1px dashed var(--border-color);
    text-decoration: none;
  }

  .list-link:hover {
    border-bottom-style: solid;
    border-bottom-color: var(--text-main);
  }

  .project-image {
    width: 100%;
    max-height: 220px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    margin-bottom: 1rem;
  }

  .date-meta {
    font-family: monospace;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    transition: padding 0.2s ease;
  }

  .list-link:hover .project-title {
    padding-left: 0.5rem;
  }

  .project-description {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .empty-state {
    padding: 2rem 0;
    color: var(--text-muted);
    font-style: italic;
  }
</style>

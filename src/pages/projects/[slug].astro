---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjectBySlug, type Project } from '../../lib/db';
import { getRuntimeEnv } from '../../lib/runtime';
import config from '../../../config.json';
import { formatDate, getISODate } from '../../utils/date';
import { renderMarkdown } from '../../lib/markdown';

const { slug } = Astro.params;
const env = getRuntimeEnv(Astro.locals);

let project: Project | null = null;
try {
  project = await getProjectBySlug(slug!, env);
} catch (err) {
  console.error('Project fetch error:', err);
  return new Response('Service temporarily unavailable', { status: 503 });
}

if (!project) {
  return new Response(null, { status: 404 });
}

// Hidden projects are not publicly accessible
if (project.hidden) {
  return new Response(null, { status: 404 });
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=86400');

// Check if project has code blocks (to conditionally load copy button script)
const hasCodeBlocks = project.content ? project.content.includes('```') : false;

// Render Markdown → HTML (if content exists, with caching)
const contentHtml = project.content
  ? await renderMarkdown(project.content, { gfm: true, breaks: false })
  : null;

const dateISO = getISODate(project.date);
const metaDescription = project.description || project.title;
---

<BaseLayout
  title={`${project.title} — ${config.site_name}`}
  description={metaDescription}
  activeNav="projects"
>
  <a href="/projects" class="back-link">&larr; back to projects</a>

  <article>
    <header class="project-header">
      <h1 class="project-title">{project.title}</h1>
      <div class="project-meta">
        <time datetime={dateISO}>{formatDate(project.date)}</time>
        {
          project.url && (
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
              {project.url.replace(/^https?:\/\//, '')} &rarr;
            </a>
          )
        }
      </div>
      {project.description && <p class="project-description">{project.description}</p>}
    </header>

    {contentHtml && <div class="content-body" set:html={contentHtml} />}
  </article>

{hasCodeBlocks && (
  <script>
    import { initCopyButtons } from '../../scripts/copy-button.js';
    initCopyButtons('.content-body');
  </script>
)}
</BaseLayout>

<style>
  .project-header {
    margin-top: 1.5rem;
    margin-bottom: var(--space-lg);
  }

  .project-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }

  .project-meta {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
    font-family: monospace;
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .project-link {
    color: var(--text-muted);
    font-family: monospace;
    font-size: 0.9rem;
  }

  .project-link:hover {
    color: var(--text-main);
  }

  .project-description {
    font-family: var(--font-sans);
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;

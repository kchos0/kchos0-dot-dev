{
  "name": "personal-web",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "secrets:scan": "gitleaks git --staged --redact --no-banner",
    "secrets:scan:full": "gitleaks git --redact --no-banner",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/rss": "^4.0.15",
    "@libsql/client": "^0.17.0",
    "astro": "^5.18.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "undici": "^7.22.0",
    "wrangler": "^4.69.0",
    "volar-service-yaml": "^0.0.70"
  }
}
